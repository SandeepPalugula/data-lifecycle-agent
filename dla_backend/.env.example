# Database
DATABASE_URL=postgresql+asyncpg://dla_api:yourpassword@localhost:5432/data_lifecycle_agent

# Security
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Redis
REDIS_URL=redis://localhost:6379/0

# Cloud pricing (optional — cost oracle falls back to defaults)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Agent settings
AGENT_STANDDOWN_THRESHOLD=50
AGENT_MAX_COMPUTE_LOAD_PCT=70
AGENT_PEAK_FACTOR_LIMIT=3.0
BATCH_SIZE_DEFAULT=10
#SKIP_STANDDOWN_CHECK=false
MIN_CONVERSATION_AGE_DAYS=0
